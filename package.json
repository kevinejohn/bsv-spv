{
  "name": "bsv-spv",
  "version": "3.0.0",
  "description": "Stay in sync with latest bitcoin headers, blocks and mempool txs",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "CHANGELOG.md",
    "lib",
    "src"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm run build && npm run test-types && npm run test-unit",
    "test-unit": "ts-node ./tests/regression.ts",
    "test-types": "tsc --noEmit --ignoreConfig --target es2016 --module Node16 --moduleResolution node16 --esModuleInterop --strict --skipLibCheck tests/*.ts",
    "test-cluster": "npm run test-live:bsv",
    "test-live": "npm run test-live:bsv",
    "test-live:bch": "ts-node ./tests/cluster_bch.ts",
    "test-live:bsv": "ts-node ./tests/cluster_bsv.ts",
    "test-live:btc": "ts-node ./tests/cluster_btc.ts",
    "test-lister": "ts-node ./tests/listener.ts",
    "test-listener": "ts-node ./tests/listener.ts",
    "test-server": "ts-node ./tests/server.ts",
    "build": "tsc",
    "docs": "typedoc",
    "prepare": "npm run build",
    "prepublishOnly": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinejohn/bsv-spv.git"
  },
  "author": "Kevin Johnson",
  "license": "MIT",
  "keywords": [
    "bitcoin",
    "spv",
    "headers"
  ],
  "dependencies": {
    "bsv-headers": "^3.0.5",
    "bsv-minimal": "^3.0.1",
    "bsv-p2p": "^3.0.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "levelup": "^5.1.1",
    "lmdb": "^3.5.4",
    "rocksdb": "^5.2.1",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/levelup": "^5.1.5",
    "@types/node": "^25.6.0",
    "@types/rocksdb": "^3.0.5",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3"
  }
}
